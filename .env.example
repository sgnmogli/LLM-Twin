# --- Required settings even when working locally. ---

# OpenAI API Config
OPENAI_MODEL_ID=gpt-4o-mini
OPENAI_API_KEY="<your_openai_api_key_here>"

# Huggingface API Config
HUGGINGFACE_ACCESS_TOKEN="<your_huggingface_access_token_here>"

# Comet ML (during training and inference) 
COMET_API_KEY="<your_comet_api_key_here>"

# --- Required settings when deploying the code. ---
# --- Otherwise, default values work fine. ---

# MongoDB database
DATABASE_HOST="mongodb://llm_engineering:llm_engineering@127.0.0.1:27017"

# Qdrant vector database
USE_QDRANT_CLOUD=false
QDRANT_CLOUD_URL="<your_qdrant_cloud_url_here>"
QDRANT_APIKEY="<your_qdrant_api_key_here>"

# AWS Authentication
AWS_ARN_ROLE="<your_aws_arn_role_here>"
AWS_REGION=eu-central-1
AWS_ACCESS_KEY="<your_aws_access_key_here>"
AWS_SECRET_KEY="<your_aws_secret_key_here>"
